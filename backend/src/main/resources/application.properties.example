spring.application.name=ordering-system
# 1. \u8CC7\u6599\u5EAB\u9023\u7DDA\u8A2D\u5B9A (\u544A\u8A34\u7A0B\u5F0F\u51B0\u7BB1\u5728\u54EA\u88E1)
# jdbc:mysql://\u7DB2\u5740:Port/\u8CC7\u6599\u5EAB\u540D\u7A31
spring.datasource.url=jdbc:mysql://localhost:3306/ordering_system?serverTimezone=Asia/Taipei&characterEncoding=utf-8

# \u8CC7\u6599\u5EAB\u5E33\u865F
spring.datasource.username=root
spring.datasource.password=Fy25228305~


# 2. JPA \u8A2D\u5B9A (\u8B93 Java \u81EA\u52D5\u5E6B\u4F60\u7522\u751F SQL \u7684\u9B54\u6CD5)
# update: \u7576\u7A0B\u5F0F\u555F\u52D5\u6642\uFF0C\u5982\u679C Java \u7269\u4EF6\u8DDF\u8CC7\u6599\u5EAB\u8868\u9577\u5F97\u4E0D\u4E00\u6A23\uFF0C\u81EA\u52D5\u5E6B\u4F60\u4FEE\u6539\u8CC7\u6599\u5EAB\u8868
spring.jpa.hibernate.ddl-auto=update

# \u8B93\u4ED6\u5728 Console \u5370\u51FA SQL \u8A9E\u6CD5 (\u65B9\u4FBF\u6211\u5011\u9664\u932F\uFF0C\u770B\u5B83\u5230\u5E95\u5C0D\u8CC7\u6599\u5EAB\u505A\u4E86\u4EC0\u9EBC)
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true